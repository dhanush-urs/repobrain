# -----------------------------
# App Environment
# -----------------------------
APP_ENV=development
APP_NAME=RepoBrain
APP_VERSION=0.1.0

# -----------------------------
# Web / API
# -----------------------------
WEB_PORT=3000
API_PORT=8000
WEB_URL=http://localhost:3000
API_URL=http://localhost:8000

# -----------------------------
# Backend Security
# -----------------------------
SECRET_KEY=change_me_super_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000

# -----------------------------
# PostgreSQL
# -----------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=repobrain
POSTGRES_USER=repobrain
POSTGRES_PASSWORD=repobrain

# SQLAlchemy URL (inside docker)
DATABASE_URL=postgresql+psycopg://repobrain:repobrain@postgres:5432/repobrain

# -----------------------------
# Redis
# -----------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# -----------------------------
# Celery
# -----------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# -----------------------------
# Neo4j
# -----------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=repobrainneo4j

# -----------------------------
# LLM / Embeddings
# -----------------------------
LLM_PROVIDER=gemini        # gemini | none
EMBEDDING_PROVIDER=local   # local (sentence-transformers) | gemini
ENABLE_GEMINI=false        # set to true only after adding a valid key

# SECURITY: Never hardcode your API key. Rotate if exposed.
GEMINI_API_KEY=your_key_here
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# -----------------------------
# GitHub
# -----------------------------
# Required for private repositories. Generate at:
# https://github.com/settings/tokens  (classic token, repo scope)
# Leave empty to use public repositories only.
GITHUB_TOKEN=

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# -----------------------------
# Repo Storage
# -----------------------------
REPO_STORAGE_PATH=/app/data/repos
TEMP_STORAGE_PATH=/app/data/tmp

# -----------------------------
# Observability (later)
# -----------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=